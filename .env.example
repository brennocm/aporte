# --- Aporte Framework Environment Variables ---

# NextAuth Secret (REQUIRED: Generate with 'openssl rand -base64 32')
AUTH_SECRET=your_32_character_secret_key_at_least

# Admin Password (OPTIONAL: For automation scripts, but not required for GUI)
ADMIN_PASSWORD=aporte123

# Math Engine URL (Default for Docker)
NEXT_PUBLIC_API_URL=http://math-engine:8000

# Prisma Database (Default for Docker)
DATABASE_URL=file:/app/apps/web/prisma/dev.db
